# Strict profile: safer/stricter filtering for production-like screening
# Copy keys below into .env (keep your TELEGRAM_* existing values)

REQUIRE_FORECAST=true
FORECAST_PERIODS=20
FORECAST_EDGE=0.0
FORECAST_MIN_POINTS=8
FORECAST_MIN_R2=0.12
FORECAST_MAX_RESIDUAL_STD=0.0008
FORECAST_MAX_RELATIVE_STD=0.7
FORECAST_MIN_PREDICTED=0.0003
MIN_VOLUME=500000
MIN_BASIS=0.0005
